# 請複製此檔為 .env 並填入你的金鑰（.env 不進 git）

# ─────────────────────────────────────────
# 資料來源
# ─────────────────────────────────────────
FINMIND_TOKEN=your_finmind_token_here
FUGLE_API_KEY=your_fugle_api_key_here
FUGLE_ACCOUNT=your_fugle_account_here

# ─────────────────────────────────────────
# Claude API（新聞情緒分析）
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─────────────────────────────────────────
# 隱私保護：asset_manager 讀取 assets.json 前檢查此 UUID
# 不符則金額遮罩為 ***（避免醫院查房時被瞥見）
# ─────────────────────────────────────────
USER_UUID=set-a-long-random-string-here

# ─────────────────────────────────────────
# 選配（第二階段才用）
# ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# LINE_NOTIFY_TOKEN=
