# 韭菜健檢 — Streamlit Secrets 範本
#
# 本地開發:複製為 .streamlit/secrets.toml 並填值(這個檔 .gitignore 已排除)
# Streamlit Cloud:Dashboard → App → Settings → Secrets 貼上同樣內容

# ─── Supabase(多 user 模式必填,不填則 fallback 本機單機)─────────
SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY = "eyJxxx_your_anon_public_key_xxx"

# ─── AI(三選一,沒填則 Gemini 區塊顯示「加 key 提示」)──────────
GEMINI_API_KEY = "AQ.YOUR_KEY"
# ANTHROPIC_API_KEY = "sk-ant-YOUR_KEY"      # 可選,若用 Claude
# OPENAI_API_KEY = "sk-proj-YOUR_KEY"        # 可選,若用 GPT

# ─── FinMind(歷史財報資料,有 key 可下載完整 5 年 backfill)────
# FINMIND_TOKEN = "YOUR_FINMIND_TOKEN"
