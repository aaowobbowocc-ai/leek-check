__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
config/.env
data/assets.json
data/cache/
# 例外:ticker 對照表(部署必備,~83KB)
!data/cache/
!data/cache/finmind/
!data/cache/finmind/extras/
!data/cache/finmind/extras/stock_info.parquet
!data/cache/finmind/ipo/
!data/cache/finmind/ipo/ipo_list.parquet
# 其他 cache 子目錄全部排除
data/cache/finmind/finmind/
data/cache/finmind/institutional/
data/cache/finmind/holding/
data/cache/finmind/revenue/
data/cache/finmind/financial/
data/cache/finmind/dividend/
data/cache/finmind/margin/
data/cache/finmind/minute/
data/cache/finmind/tick/
data/cache/yfinance/
data/history/
data/paper_trades/
data/backtest/
# 策略 pre-compute 結果(本機跑 scripts/precompute_strategy_results.py 產出,
# 雲端讀此 JSON 秒出全市場結果)
!data/strategy_results.json
logs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.parquet
*.png
!app/static/*.png

# 例外:ticker 對照表 + IPO list(小檔,部署必備)
!data/cache/finmind/extras/stock_info.parquet
!data/cache/finmind/ipo/ipo_list.parquet
.claude/

# Streamlit secrets(API keys / Supabase URL+anon key)
.streamlit/secrets.toml

# 本機 user data(部署後 Supabase 接管)
app/user_data/*.json

# AI cache(每用戶獨立)
app/data/ai_cache/

# IDE
.vscode/
.idea/
*.swp

# Private docs(audit, review, internal planning)排除整個 docs/
# 但允許 GitHub Pages 公開頁面(privacy + 行銷 landing + 帳號刪除)
docs/*
!docs/privacy.html
!docs/index.html
!docs/delete-account.html

# Capacitor / Android build artifacts
mobile/node_modules/
mobile/android/build/
mobile/android/.gradle/
mobile/android/app/build/
mobile/android/local.properties
mobile/android/.idea/
mobile/android/captures/
mobile/android/*.iml
mobile/android/app/*.iml
mobile/ios/App/Pods/
mobile/ios/App/Podfile.lock
mobile/ios/App/build/
mobile/ios/.xcode.env.local

# Web (Next.js) v2 frontend
web/node_modules/
web/.next/
web/out/
web/.env.local
web/.env*.local
web/.vercel/
web/*.tsbuildinfo

# Android signing keystore — NEVER commit these (will lose Play Store ownership!)
mobile/android/keystore/*.jks
mobile/android/keystore/keystore.properties
