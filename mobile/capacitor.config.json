{
  "appId": "tw.leekcheck.app",
  "appName": "韭菜健檢",
  "webDir": "www",
  "server": {
    "url": "https://leek-check.vercel.app",
    "androidScheme": "capacitor",
    "cleartext": false,
    "iosScheme": "leekcheck",
    "allowNavigation": [
      "leek-check.vercel.app",
      "*.vercel.app",
      "leek-check-api.onrender.com",
      "*.onrender.com",
      "*.supabase.co",
      "accounts.google.com",
      "*.googleapis.com",
      "*.googleusercontent.com",
      "*.gstatic.com"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": true,
    "buildOptions": {
      "releaseType": "AAB"
    }
  },
  "ios": {
    "contentInset": "always",
    "scheme": "leekcheck",
    "preferredContentMode": "mobile"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#0f766e",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f766e",
      "overlaysWebView": false
    },
    "App": {
      "backButtonExit": false
    },
    "Keyboard": {
      "resize": "native",
      "style": "DARK",
      "resizeOnFullScreen": true
    }
  }
}
